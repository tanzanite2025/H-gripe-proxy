{
  "version": "0.0.5",
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "bundle": {
    "active": true,
    "longDescription": "H-gripe-proxy",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources"
    ],
    "publisher": "tanzanite2025",
    "copyright": "GNU General Public License v3.0",
    "category": "DeveloperTool",
    "shortDescription": "H-gripe-proxy",
    "createUpdaterArtifacts": true
  },
  "build": {
    "beforeBuildCommand": "pnpm run web:build",
    "frontendDist": "../dist",
    "beforeDevCommand": "pnpm run web:dev",
    "devUrl": "http://127.0.0.1:3500/",
    "removeUnusedCommands": true
  },
  "productName": "H-gripe-proxy",
  "identifier": "io.github.tanzanite2025.h-gripe-proxy",
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://update.hwdns.net/https://github.com/tanzanite2025/H-gripe-proxy/releases/download/updater/update-proxy.json",
        "https://github.com/tanzanite2025/H-gripe-proxy/releases/download/updater/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ2NjJBMUZGRDhFN0M5REIKUldUYnllZlkvNkZpUms0anNHcktTbm1BNGtITnM1OUxDaTh0aGxyVk9CeW4zbmFybGMvOW85WVAK"
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "clash",
          "clash-verge"
        ]
      }
    }
  },
  "app": {
    "security": {
      "capabilities": [
        "desktop-capability",
        "migrated"
      ],
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPDATA/**",
            "$APPCONFIG/**",
            "$CACHE/**"
          ],
          "requireLiteralLeadingDot": false
        }
      },
      "csp": "default-src 'self'; connect-src 'self' 127.0.0.1 http://127.0.0.1:* ws://127.0.0.1:* http://ipc.localhost http://tauri.localhost; img-src 'self' asset: data: https://* http://tauri.localhost; style-src 'self' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com http://tauri.localhost; script-src 'self' 'unsafe-inline';"
    }
  }
}
